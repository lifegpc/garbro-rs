{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    {
      "identifier": "fs:allow-read",
      "allow": [{ "path": "**" }] 
    },
    {
      "identifier": "fs:allow-write",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "**" }]
    },
    "fs:allow-exists"
  ]
}
